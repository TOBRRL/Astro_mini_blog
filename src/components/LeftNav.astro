---
const navItems = [
  { name: "POSTS", href: "/blog" },
  { name: "TAGS", href: "/tags" },
  { name: "ABOUT", href: "#" },
];
---

<nav class="flex flex-col gap-5">
  <div class="space-y-1">
    <div class="text-[11px] text-blue-400 font-bold tracking-[0.3em] uppercase opacity-80">
      Navigation
    </div>
    <div class="h-[1px] w-8 bg-blue-500/50"></div> </div>

  <div class="flex flex-col gap-3">
    {navItems.map(item => (
      <a 
        href={item.href} 
        class="text-xs font-mono text-gray-500 hover:text-white transition-all duration-300 hover:pl-2 border-l border-transparent hover:border-blue-500 pl-0"
      >
        [{item.name}]
      </a>
    ))}
  </div>
</nav>