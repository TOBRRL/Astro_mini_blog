---
const navItems = [
  { name: "POSTS", href: "/blog" },
  { name: "TAGS", href: "/tags" },
  { name: "ABOUT", href: "#" },
];
---

<nav class="flex flex-col gap-6">
  <div class="space-y-2">
    <div class="text-[18px] text-blue-900 font-black tracking-[0.3em] uppercase">
      Navigation
    </div>
    <div class="h-[2px] w-10 bg-blue-600"></div> 
  </div>

  <div class="flex flex-col gap-4">
    {navItems.map(item => (
      <a 
        href={item.href} 
        class="text-[1.1rem] font-mono font-bold text-zinc-800 hover:text-blue-600 transition-all duration-300 hover:pl-3 border-l-2 border-transparent hover:border-blue-600 pl-0"
      >
        [{item.name}]
      </a>
    ))}
  </div>
</nav>