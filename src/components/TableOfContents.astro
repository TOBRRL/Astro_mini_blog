---
const { headings } = Astro.props;
const filteredHeadings = headings.filter((h: any) => h.depth > 1 && h.depth < 4);
---

<nav class="flex flex-col gap-6">
  <div class="space-y-2">
    <div class="text-[14px] font-black tracking-[0.2em] uppercase text-zinc-900">
      Contents // Index
    </div>
    <div class="h-[2px] w-10 bg-zinc-900"></div>
  </div>

  <div class="flex flex-col gap-3">
    {filteredHeadings.map((h: any) => (
      <a
        href={`#${h.slug}`}
        class={`text-[1.05rem] transition-all hover:text-blue-600 text-zinc-700 leading-snug
          ${h.depth === 3 ? "pl-6 text-[0.95rem] border-l border-zinc-200" : "font-bold"}`}
      >
        {h.text}
      </a>
    ))}
  </div>
</nav>