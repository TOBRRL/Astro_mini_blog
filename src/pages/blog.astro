---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import LeftNav from "../components/LeftNav.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <div class="fixed left-16 top-32 hidden lg:block w-32">
    <LeftNav />
  </div>

  <main class="lg:ml-56 max-w-4xl text-left pt-0">
    <h2 class="text-3xl font-bold mb-8 text-black uppercase leading-tight">Writing</h2>

    <div class="flex flex-col gap-4">
      {
        posts.map((post) => (
          <a
            class="hover:bg-zinc-100 -mx-3 flex flex-col rounded-md px-3 py-3 no-underline transition-colors border border-transparent hover:border-zinc-200"
            href={`/blog/${post.id}`}
          >
            <div class="flex items-baseline justify-between gap-4">
              <span class="font-bold text-black text-lg">{post.data.title}</span>
              <span class="text-[11px] font-mono opacity-50 uppercase shrink-0">
                {post.data.date?.toISOString().split('T')[0]}
              </span>
            </div>
            
            <span class="text-zinc-500 text-sm mt-1">{post.data.description}</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>

<style is:global>
  main {
    margin-left: 0 !important;
  }
  
  @media (min-width: 1024px) {
    main {
      margin-left: 14rem !important;
      max-width: 50rem !important;
    }
  }

  .fixed.left-16 a {
    font-weight: 800 !important;
    text-transform: uppercase;
  }
</style>