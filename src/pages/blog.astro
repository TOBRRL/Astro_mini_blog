---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import LeftNav from "../components/LeftNav.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  {/* 保持和文章页完全一样的 fixed 位置 */}
  <div class="fixed left-16 top-48 hidden lg:block w-32">
    <LeftNav />
  </div>

  {/* 重点在这里：去掉 mt-40，改用 pt-12 (约 48px) 来精确抵消首页缺少 Header 带来的高度差 */}
  {/* 加上 Layout 里的 py-6 (24px)，总间距会落在 72px 左右，这通常是 h1/h2 顶部对齐侧边栏的黄金值 */}
  <main class="lg:ml-44 max-w-4xl text-left pt-0">
    {/* 移除 mt-2，这是导致首页标题下沉的元凶 */}
    <h2 class="text-3xl font-bold mb-8 text-black uppercase leading-none">Writing</h2>

    <div class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <a
            class="hover:bg-zinc-100 -mx-3 flex flex-col rounded-md px-3 py-2 no-underline transition-colors"
            href={`/blog/${post.id}`}
          >
            <span class="font-medium text-black">{post.data.title}</span>
            <span class="text-zinc-500 text-sm">{post.data.description}</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  main {
    margin-left: 0 !important;
    margin-right: auto !important;
  }
  
  @media (min-width: 1024px) {
    main {
      margin-left: 11rem !important; 
      max-width: 56rem !important;
    }
  }
</style>