---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

// 仅保留文章获取逻辑，删除了无用的 Item 接口和 projects 数组
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <main class="text-left p-0 m-0 max-w-none">
    
    <h2 class="text-xl font-bold mb-6 mt-2">Writing</h2>

    <div class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={`/blog/${post.id}`}
          >
            <span class="font-medium">{post.data.title}</span>
            <span class="text-muted-foreground text-sm">{post.data.description}</span>
          </a>
        ))
      }
    </div>

  </main>
</Layout>

<style>
  /* 由于 Layout.astro 可能自带了居中容器（如 max-w-screen-md），
     这里强制让 main 标签打破居中逻辑。
  */
  main {
    margin-left: 0 !important;
    margin-right: auto !important;
  }
</style>