---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import LeftNav from "../components/LeftNav.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <div class="fixed left-16 top-48 hidden lg:block w-32">
    <LeftNav />
  </div>

  <main class="text-left p-0 m-0 lg:ml-44 max-w-4xl">
    <h2 class="text-xl font-bold mb-6 mt-2">Writing</h2>

    <div class="flex flex-col gap-2">
      {
        posts.map((post) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={`/blog/${post.id}`}
          >
            <span class="font-medium">{post.data.title}</span>
            <span class="text-muted-foreground text-sm">{post.data.description}</span>
          </a>
        ))
      }
    </div>
  </main>
</Layout>

<style>
  main {
    margin-left: 0 !important;
    margin-right: auto !important;
  }
  
  @media (min-width: 1024px) {
    main {
      margin-left: 11rem !important; 
      max-width: 56rem !important;
    }
  }
</style>