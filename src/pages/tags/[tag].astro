---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LeftNav from '../../components/LeftNav.astro'; // 必须引入

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`Tag: ${tag}`}>
  <div class="fixed left-16 top-32 hidden lg:block w-32">
    <LeftNav />
  </div>

  <main class="lg:ml-44 max-w-4xl text-left">
    <div class="flex items-center gap-3 mb-12">
      <span class="text-xs font-bold tracking-[0.3em] uppercase text-blue-400 opacity-80">Tag //</span>
      <h1 class="text-xl font-mono uppercase text-zinc-900">{tag}</h1>
    </div>

    <ul class="flex flex-col gap-8 p-0 m-0">
  {posts.map((post) => (
    /* 核心：list-none 去掉点，但它依然是 block 容器 */
    <li class="group list-none">
      <a href={`/blog/${post.id}`} class="block no-underline">
        <div class="flex items-baseline justify-between gap-4">
          <span class="text-2xl font-black text-black group-hover:text-blue-600 transition-all group-hover:translate-x-2">
            {post.data.title}
          </span>
          
          <span class="text-[12px] font-mono opacity-50 uppercase shrink-0">
            {post.data.date?.toISOString().split('T')[0]}
          </span>
        </div>
      </a>
    </li>
  ))}
</ul>

    <a href="/tags" class="inline-block mt-12 text-xs font-mono text-zinc-400 hover:text-blue-500">
      [ BACK TO INDEX ]
    </a>
  </main>
</Layout>