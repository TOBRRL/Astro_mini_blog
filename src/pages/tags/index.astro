---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import LeftNav from '../../components/LeftNav.astro'; // 必须引入

const allPosts = await getCollection('blog');
const tags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())].sort();
---

<Layout title="TAGS INDEX">
  <div class="fixed left-16 top-32 hidden lg:block w-32">
    <LeftNav />
  </div>

  <main class="lg:ml-44 max-w-4xl text-left">
    <h1 class="text-2xl font-bold mb-12 text-zinc-900 uppercase tracking-[0.2em] font-mono">
      Tags Index
    </h1>

    <section>
      <h2 class="text-[11px] font-bold tracking-[0.3em] text-blue-500 uppercase mb-8 border-b border-zinc-100 pb-2">
        All Tags
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-y-6 gap-x-8">
        {tags.map((tag) => (
          <a href={`/tags/${tag}`} class="group flex items-center gap-2">
            <span class="text-zinc-300 group-hover:text-blue-500 transition-colors font-mono">#</span>
            <span class="text-sm font-mono text-zinc-600 group-hover:text-zinc-900 group-hover:underline transition-all uppercase">
              {tag}
            </span>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>