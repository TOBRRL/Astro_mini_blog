---
import { type CollectionEntry, getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import LeftNav from "../../components/LeftNav.astro";
import TableOfContents from "../../components/TableOfContents.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content, headings } = await render(post);
const { tags } = post.data;
---

<Layout
  title={post.data.title}
  description={post.data.description}
  image={post.data.image}
>
  <div class="fixed left-16 top-32 hidden lg:block w-32">
    <LeftNav />
  </div>

  <div class="fixed right-6 top-32 hidden xl:block w-48">
    <TableOfContents headings={headings} />
  </div>

  <main class="lg:ml-44 xl:mr-56 max-w-4xl text-left pt-0 !mt-16">
    <div class="flex items-baseline justify-between gap-4 mb-4">
      <h1 class="text-3xl font-bold text-black uppercase leading-tight m-0">
        {post.data.title}
      </h1>
      <span class="text-[12px] font-mono opacity-50 uppercase shrink-0">
        {post.data.date?.toISOString().split('T')[0]}
      </span>
    </div>

    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-4 mb-8 items-center border-b border-zinc-100 pb-6">
        <span class="text-[10px] text-zinc-400 font-bold tracking-[0.2em] uppercase">
          Filed under:
        </span>
        {tags.map((tag: string) => (
          <a 
            href={`/tags/${tag}`} 
            class="text-[11px] font-mono font-bold text-zinc-500 hover:text-black transition-colors uppercase tracking-widest"
          >
            # {tag}
          </a>
        ))}
      </div>
    )}

    <article class="prose prose-zinc max-w-none">
      <Content />
    </article>
  </main>
</Layout>

<script>
  const setupFoldableHeadings = () => {
    const article = document.querySelector('article');
    if (!article) return;

    const headings = article.querySelectorAll('h1, h2, h3, h4, h5, h6');
    headings.forEach(heading => {
      if (heading.textContent?.includes('+')) {
        if (heading.parentElement?.tagName === 'DETAILS') return;

        const details = document.createElement('details');
        details.open = true; 
        
        if (heading.id) {
          details.id = heading.id;
          heading.removeAttribute('id');
        }

        const summary = document.createElement('summary');
        summary.classList.add(heading.tagName.toLowerCase());
        summary.innerHTML = heading.innerHTML.replace('+', '');
        details.appendChild(summary);

        const currentLevel = parseInt(heading.tagName.substring(1));
        let next = heading.nextElementSibling;

        while (next) {
          const nextTagName = next.tagName;
          if (/^H[1-6]$/.test(nextTagName)) {
            const nextLevel = parseInt(nextTagName.substring(1));
            if (nextLevel <= currentLevel) break;
          }
          const nodeToMove = next;
          next = next.nextElementSibling;
          details.appendChild(nodeToMove);
        }

        heading.parentNode?.insertBefore(details, heading);
        heading.remove();
      }
    });
  };

  document.addEventListener('astro:page-load', setupFoldableHeadings);
  setupFoldableHeadings();
</script>

<style is:global>
  /* 统一左侧导航字重 */
  .fixed.left-16 a {
    font-weight: 800 !important;
    text-transform: uppercase;
  }

  html {
    scroll-behavior: smooth;
  }

  article :is(h1, h2, h3, h4, h5, h6), 
  summary {
    color: #000 !important;
    font-weight: 800 !important;
    line-height: 1.3 !important;
    letter-spacing: -0.025em !important;
    display: flex !important;
    align-items: center !important;
    margin-top: 2.5rem !important;
    margin-bottom: 1rem !important;
  }

  article blockquote {
    border-left: 4px solid #3b82f6 !important;
    background-color: #f8fafc !important; 
    padding: 1rem 1.5rem !important;
    margin: 2rem 0 !important;
    font-style: italic !important;
    color: #475569 !important;
  }

  article li {
    display: list-item !important;
    list-style-position: inside !important;
    margin-bottom: 0.5rem !important;
  }

  summary {
    cursor: pointer !important;
    list-style: none !important;
    outline: none !important;
  }

  summary::after {
    content: "▼";
    font-size: 0.6em;
    margin-left: 0.5rem;
    transition: transform 0.3s ease;
  }

  details:not([open]) summary::after {
    transform: rotate(-90deg);
  }

  summary::-webkit-details-marker { display: none !important; }
</style>